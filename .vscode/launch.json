{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Cms.Web (dotnet run)",
      "type": "coreclr",
      "request": "launch",

      "program": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/Cms.Web"
      ],

      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,

      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },

      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
