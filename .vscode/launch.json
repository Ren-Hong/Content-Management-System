{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Cms.Web",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Cms.Web/bin/Debug/net10.0/Cms.Web.dll",
      "cwd": "${workspaceFolder}/Cms.Web",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}